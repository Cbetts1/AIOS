#!/usr/bin/env python3
"""
aura — AURA OS Command-Line Interface
Entry point for all AURA commands.

Usage:
    aura <command> [args...]
    aura help
"""

import os
import sys
from pathlib import Path

# ── Ensure the AIOS root is on sys.path so imports work regardless of CWD ──
_ROOT = Path(__file__).resolve().parent
if str(_ROOT) not in sys.path:
    sys.path.insert(0, str(_ROOT))

# ── Set AURA_HOME if not already set ────────────────────────────────────────
if "AURA_HOME" not in os.environ:
    os.environ["AURA_HOME"] = str(Path.home() / ".aura")


def main():
    from core.engine import CommandEngine
    engine = CommandEngine()
    engine.run(sys.argv[1:])


if __name__ == "__main__":
    main()
